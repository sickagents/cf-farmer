# IMAP config for email verification polling
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASS=your-app-password

# Email domain for generated accounts
DOMAIN=yourdomain.com

# Solverify Turnstile solver API key
SOLVERIFY_API_KEY=your-solverify-key

# 9router inject mode (optional)
# sqlite = local DB (default, same machine as 9router)
# http://HOST:PORT = remote API (e.g. http://43.159.60.190:20128)
CF_INJECT_MODE=sqlite
